#!/usr/bin/env zsh

# Abort if RetroArch is already running.
if pgrep -x RetroArch &> /dev/null; then
	exit
fi

contents=${ZSH_SCRIPT:h:h}

core=`plutil -extract EmuCorePath raw $contents/info.plist`
if [[ -f $contents/Frameworks/$core:t ]]; then
  core=$contents/Frameworks/$core:t
fi

rom=`plutil -extract EmuROMPath raw $contents/info.plist`
for r in $rom:t $rom:h:t/$rom:t; [[ -f $resources/${r%\#*} ]] && {
  rom=$resources/$r
}

# a: hardware arch. arm64 or x86_64
# b: core arch. arm64 and/or x86_64
# c: hardware aligned core arch with fallsback. arm64 or x86_64
# `open` called with arch flag supported by the core.
# Required for x86 cores on arm hardware.
a=( `uname -m` ) b=( `lipo -archs $core` ) c=( ${${b:*a}:-$b} )
largs=( --arch $c )

config=( $contents/Resources/*.cfg )

open $largs -b com.libretro.dist.RetroArch  --args $@ --appendconfig ${(j[|])config} -L $core $rom

for sh in $contents/Scripts/post-boot*.sh(N); do
  source $sh
done
