#!/usr/bin/env zsh

zparseopts -D -E -F - \
  -process-all=process_all \
  -process-existing=process_existing \
  -favorites=_favorites \
  -history=_history \
  {p,-playlist}:=playlist \
  {t,-template}:=template \
  {h,-help}=help || {
    print "see --help" >&2
    return 1
  }

if [[ -n $help ]]; then
cat <<- --------
usage: rashortcuts [OPTION]... [OUTPUT]

Playlists:
  --favorites         favorites playlist
  --history           history playlist
  -p, --playlist      path/to/playlist.lpl

If a playlist is not provided, fzf will list them automatically.

Process without fzf game selection.
  --process-all       process all entries for a given playlist
  --process-existing  process entries for a given playlist that already exists in
                      the output directory.

Last argument should point to the directory where the shortcut.app will be created.
Defaults to the current working directory.

Custom templates:
  -t, --template      path/to/template-folder

An optional template for building shortcuts. It defaults to the folder named
"template" located in the same directory as this script. If a hidden .template
folder exists in the output directory, it will be used instead but --template
will always take presidence.

  -h, --help          view help.

--------
return
fi

# Print with style.
p.header(){ printf "\n\e[1;30m%s\e[0m\n" $@ }
p.ok()    { printf   "\e[0;30m%s\e[0m\n" $@ }
p.warn()  { printf   "\e[0;33m%s\e[0m\n" $@ }
p.error() { printf   "\e[0;31m%s\e[0m\n" $@ >&2 }

# Print os version as a float.
p.os_version() {
  local os_version=`sw_vers -productVersion`
  float os_version=${os_version%%.*}.${${os_version#*.}//./}
  print -- $os_version
}

# Check requirements.
c.requirements() {
  for r in $@; if ! type $r &>/dev/null; then
    p.error "$r is required."
    __s=1
  fi
  return ${__s:-0}
}

# Make .icns files.
m.icns() {
  local icnset=${TMPDIR}`uuidgen`.iconset
  mkdir $icnset
  sips -j $this_dir/makeicnset.js $1 -o $icnset
  iconutil -c icns $icnset -o $2
  rm -rf $icnset
}

# check for all requirements before exiting.
() {
  c.requirements fzf jq
  (( `p.os_version` >= 26 )) && c.requirements fileicon
} || return 1

output=${1:-.}

app_support=~/Library/Application\ Support/RetroArch
this_dir=$(dirname `realpath $0`)

# order of prescidence:
# - calling with -t|--template <template/path>
# - hidden .template folder in the $output directory.
# - default template provided with the script.
if [[ -n $template[-1] ]]; then
  template=$template[-1]
elif [[ -d $output/.template ]]; then
  template=$output/.template
else
  template=$this_dir/template
fi

for f in info.plist MacOS/launcher; [[ -f $template/Contents/$f ]] || {
  p.error "Check template: $f:t file not found." \
          "- $template/Contents/$f"
  return 1
}

if [[ -n $playlist ]]; then
  playlist=${playlist[-1]}
else
  for k in _favorites _history; [[ -n ${(P)k} ]] && {
    content_path=$(eval printf %s $(
      awk -F= "/content${k}_path/ { print \$2 }" $app_support/config/retroarch.cfg
    ))
    playlist=${content_path/#\~/$HOME}
    break
  }
fi

if [[ ! -n $playlist ]]; then
  playlistdir=$(eval printf %s $(
    awk -F= '/playlist_directory/ {print $2}' $app_support/config/retroarch.cfg
  ))
  playlist=$(
    for lpl in ${playlistdir/#\~/$HOME}/*.lpl; do
      print -- "$lpl\t$lpl:t:r"
    done | fzf --delimiter '\t' --with-nth 2 --preview "jq -r '.items[].label' {1}" | cut -f1
  )
  if [[ ! -n $playlist ]]; then
    p.warn "Nothing selected."
    return
  fi
fi

if [[ ! -f $playlist ]]; then
  p.error "Playlist does not exist:" \
          "- $playlist"
  return 1
fi

# json list of cleaned up items.
# Ensure .label and .db_name are present.
items=$(
  jq '.items[] | select(( .label | length > 0 ) and ( .db_name | length > 0 )) | {
    system:.db_name|sub(".lpl"; ""),
    label: .label,
    gpath: .path,
    cname: .core_name,
    cpath: .core_path
  }' $playlist | jq -n '[inputs]'
)

limit=`print -- $items | jq 'length'`
if [[ -n $process_all ]] || [[ -n $process_existing ]]; then
  work_indices=($(
    for (( i=0; i!=$limit; i++ )); print -- $i
  ))
else
  work_indices=($(
    for (( i=0; i!=$limit; i++ )); do
      print -- "$i\t`print -- $items | jq -r ".[$i].label"`"
    done | fzf --multi --delimiter '\t' --with-nth 2 | cut -f1
  ))
fi

if [[ -z $work_indices ]]; then
  p.warn "Nothing to process."
  return
fi

# hidden templates can be easily forgotten.
if [[ $template =~ "\/\." ]]; then
  p.warn "Using template: ${${template:a}/#$HOME/~}"
fi

default_cname=`jq -r ".default_core_name" $playlist`
default_cpath=`jq -r ".default_core_path" $playlist`

IFS=$'\n'
for i in $work_indices; do
  read -d '' system label gpath cname cpath < <(
    print -- $items | jq -r ".[$i] | .system, .label, .gpath, .cname, .cpath"
  )
  cname=${${cname/DETECT}:-$default_cname}
  cpath=${${cpath/DETECT}:-$default_cpath}

  if [[ -z $cpath ]]; then
    p.error "Core could not be determined from the playlist. Do one of the following:" \
            "- Set a default core for the playlist. (recommended)" \
            "- Run the game in RetroArch at least once from the playlist."
    continue
  fi

  # Make label file system safe.
  # - replace ':' with '：' [Unicode U+FF1A] and '.'
  # - replace '/' with '᜵'. [Unicode U+1735]
  shortcut_app=$output/${${${label//: /：}//:/.}//\//᜵}.app

  if [[ -n $process_existing ]] && [[ ! -d $shortcut_app ]]; then
    continue
  fi

  # Create the app bundle.
  p.header "$shortcut_app:t"

  shortcut_tmp=`mktemp -dt rashortcut`
  if ! cp -R $template/Contents $shortcut_tmp; then
    p.error "Could not create $shortcut_app:t."
    rm -rf $shortcut_tmp
    continue
  fi

  # gpathextended:full game path including possible archive pointer.
  # gpath: game path without the archived pointer.
  # gcont: game container or parent directory name.
  # gfile: game file name with extension.
  # fname: name of the game file without extension.
  # aname: name of archive pointer. Empty if not present.
  # label: name from playlist label field usually taken from a database.

  unset match
  [[ $gpath:t =~ "(.*\.[[:alnum:]]{2,3})\#(.*)\.[[:alnum:]]{2,4}$" ]]
  gpathextended=$gpath
  gpath=$gpath:h/${match[1]:-$gpath:t}
  gcont=$gpath:h:t
  gfile=$gpath:t
  fname=$gpath:t:r
  aname=${match[2]}

  # INFO.PLIST: Set bundle id.
  bundleid=com.libretro
  # Limit application bundle id to alphanumerics and '-', all lower case.
  # Cut off everything before the first '- ' in system.
  # Cut off everything after ' (' and ' [' from the file name.
  for s in ${system#*- } ${${fname%% \(*}%% \[*}; bundleid+=.`printf %s ${(L)s} | tr -cd '[:alnum:]-'`
  plutil -insert CFBundleIdentifier -string $bundleid $shortcut_tmp/Contents/info.plist
  p.ok "BundleID: $bundleid"

  # LAUNCHER: Set system, rom and core.
  plutil -insert EmuSystem -string $system $shortcut_tmp/Contents/info.plist
  plutil -insert EmuROM -string $gcont/$gpathextended:t $shortcut_tmp/Contents/info.plist
  plutil -insert EmuCore -string ${cpath:t} $shortcut_tmp/Contents/info.plist

  if [[ -f $shortcut_app/Contents/Resources/$gcont/$gfile &&
      ! -L $shortcut_app/Contents/Resources/$gcont/$gfile ]]
  then
    # Do nothing. ROM already exists and is not a symlink.
    p.ok "Game: $gfile - contained"
  elif [[ -f $gpath ]]; then
    mkdir -p $shortcut_tmp/Contents/Resources/$gcont
    ln -s $gpath $shortcut_tmp/Contents/Resources/$gcont
    p.ok "Game: $gfile - linked"
  else
    p.error "$gfile not found. $playlist:t pointing to a non-existing rom:" \
            "- $gpath"
    rm -rf $shortcut_tmp
    continue
  fi

  if [[ -f $shortcut_app/Contents/Frameworks/$cpath:h &&
      ! -L $shortcut_app/Contents/Frameworks/$cpath:h ]]
  then
    # Do nothing. Core already exists and is not a symlink.
    p.ok "Core: ${cpath:t} - contained"
  elif [[ -f $cpath ]]; then
    mkdir -p $shortcut_tmp/Contents/Frameworks
    ln -s $cpath $shortcut_tmp/Contents/Frameworks
    p.ok "Core: ${cpath:t} - linked"
  else
    p.error "$cpath:t not found. $playlist:t pointing to a non-existing core:" \
            "- $cpath"
    rm -rf $shortcut_tmp
    continue
  fi

  typeset -aU thumbnames=(
    $fname
    $aname
    $label
  )

  # For each name in $thumbnames:
  # - Chop off each occurance of `(.*)` or `[.*]` from the trailing end.
  # - Add each iteration to the list of naming candidates.
  for _name in $thumbnames; while [[ $_name =~ "^(.+)(\(|\[)([^([]*)(\)|\]).*$" ]]; do
    _name=$match[1]
    # Discard trailing spaces.
    thumbnames+=${_name%${_name##*[! ]}}
  done

  appicon=$shortcut_app/Contents/Resources/AppIcon.icns
  icnpath=$shortcut_tmp/Contents/Resources/AppIcon.icns
  unset thumbpath
  update_icon=0
  for thumb in $thumbnames; do
    # Mimic RetroArch's safe naming for thumbnails.
    thumb=`printf %s $thumb | tr '&*/:\`<>?\|' '_'`
    thumbpath=$app_support/thumbnails/$system/Named_Boxarts/$thumb.png
    if [[ -f $thumbpath ]]; then
      p.ok "Boxart/$thumb.png -> $icnpath:t"
      if [[ ! -f $appicon || $thumbpath -nt $appicon ]]; then
        m.icns $thumbpath $icnpath
        update_icon=1
      fi
      break
    fi
  done

  # Use RetroSystem XMB theme content icon as a fallback.
  if [[ ! -f $thumbpath ]]; then
    fallback=$app_support/assets/xmb/retrosystem/png/$system-content.png
    if [[ -f $fallback ]]; then
      m.icns $fallback $icnpath
      p.warn "retrosystem/$system-content.png -> $icnpath:t"
    else
      p.error "$icnpath:t not copied."
    fi
  fi

  p.ok "Finalizing.."
  mkdir -p $shortcut_app
  if cp -R $shortcut_tmp/Contents $shortcut_app; then
    chmod +x $shortcut_app/Contents/MacOS/launcher
    # Work around Tahoe's icon jail.
    if (( `p.os_version` >= 26 && update_icon )); then
      if fileicon set -q $shortcut_app $appicon; then
        p.ok "Freed from icon jail"
      fi
    fi
    # Update modification date.
    touch $shortcut_app
  else
    p.error "Unable to finalize $shortcut_app:t."
  fi
  rm -rf $shortcut_tmp

done
